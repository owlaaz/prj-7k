# (Dev only) Vite dev-server proxy target for /api requests.
# Defaults to http://localhost:3001 when unset.
VITE_API_TARGET=http://localhost:3001

# Sub-path the app is served under (must start with /).
# Leave unset (defaults to /) for a root deployment.
# Set to /7k-planner for https://owlaaz.dev/7k-planner
VITE_BASE_PATH=/7k-planner

# (Production builds) Full base URL of the Kong gateway API endpoint.
# The app will call ${VITE_API_BASE}/<path> for all API requests.
# For https://api.owlaaz.dev/7k-planner with Kong strip_path=true:
VITE_API_BASE=https://api.owlaaz.dev/7k-planner/api/plannings
