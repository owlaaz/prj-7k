# Port the API server listens on (default: 3001)
PORT=3001

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=https://owlaaz.dev

# IP allowlist for upstream proxy (Kong gateway).
# Only TCP connections from these IPs are accepted.
# Leave empty (or unset) to allow all IPs — safe for local dev.
TRUSTED_PROXIES=10.0.1.10

# Optional path prefix for all routes.
# Kong strip_path=true  (default): Kong strips /7k-planner before forwarding
#   → API_PREFIX=   (empty)  → routes stay at /api/plannings
# Kong strip_path=false: Kong forwards the full path
#   → API_PREFIX=/7k-planner → routes become /7k-planner/api/plannings
API_PREFIX=/7k-planner

# libSQL / Turso database URL
# Local SQLite: file:/absolute/path/to/dev.db
# Turso:        libsql://your-db.turso.io?authToken=your-token
DATABASE_URL=file:./dev.db
